# ============================================
# Blockchain Configuration
# ============================================

# RPC URL for blockchain node
# Local: http://127.0.0.1:8545
# Sepolia: https://sepolia.infura.io/v3/YOUR_KEY
VITE_RPC_URL=http://127.0.0.1:8545

# Smart contract addresses (from deployment)
# Get these from: npx hardhat run scripts/deploy.ts --network localhost
VITE_CONTRACT_ADDRESS=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0
VITE_VERIFIER_ADDRESS=0x5FbDB2315678afccb333f8a9c45ead413b7c77bf

# ============================================
# Zero-Knowledge Proof Files
# ============================================

# WASM binary for circuit computation
VITE_WASM_URL=/zk/certify.wasm

# Proving key for Groth16
VITE_ZKEY_URL=/zk/certify.zkey

# ============================================
# Backend API
# ============================================

# Backend URL for SIWE authentication
# Local: http://localhost:4000
# Production: https://api.yourdomain.com
VITE_API_BASE_URL=http://localhost:4000

# ============================================
# IPFS Configuration (Optional)
# ============================================

# Pinata JWT token for IPFS uploads
# Get from: https://pinata.cloud
# Leave empty to disable IPFS uploads
VITE_PINATA_JWT=

# Pinata gateway URL for retrieving files
# Default: https://gateway.pinata.cloud
VITE_GATEWAY_URL=https://gateway.pinata.cloud

# ============================================
# WalletConnect Configuration (Optional)
# ============================================

# WalletConnect project ID for mobile wallets
# Get from: https://cloud.walletconnect.com
# Default demo ID works for development
VITE_WALLETCONNECT_ID=wc_demo
